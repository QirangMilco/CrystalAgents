{
  "appId": "com.qirang.crystal-agent.dev",
  "productName": "Crystal Agents Dev",
  "bundleDisplayName": "Crystal Agents Dev",
  "artifactNamePrefix": "Crystal-Agents-Dev",
  "dmgTitle": "Crystal Agents Dev",
  "deeplinkScheme": "crystalagentsdev",
  "configDirName": ".crystal-agent-dev",
  "workspaceDataDirName": ".crystal-agent-dev",
  "update": {
    "enabled": true,
    "checkOnLaunch": false,
    "autoDownload": false,
    "autoInstallOnQuit": false
  },
  "import": {
    "sourceConfigDirName": ".craft-agent",
    "copyOnFirstLaunch": false,
    "workspaceDetection": false,
    "include": [
      "config.json",
      "preferences.json",
      "credentials.enc",
      "workspaces",
      "theme.json",
      "themes",
      "permissions",
      "tool-icons"
    ]
  }
}
